# FangTrack environment variables. Copy to `.env` for local use, or set these in the
# Render dashboard (Environment tab). NEVER commit the real .env.

# REQUIRED in production: a long random string used to sign session cookies.
# Generate one:  python -c "import secrets; print(secrets.token_hex(32))"
FANGTRACK_SECRET_KEY=change-me-to-a-64-char-random-hex

# Set to 1 when served over HTTPS (Render is HTTPS) so session cookies are Secure-only.
FANGTRACK_HTTPS=1

# Database backend:
#  • Leave DATABASE_URL unset to use SQLite (FANGTRACK_DB_PATH below). Great for local dev.
#  • Set DATABASE_URL to a Postgres connection string to use Postgres (database/pg.py).
#    Render's blueprint wires this automatically from the managed database.
# DATABASE_URL=postgres://user:pass@host:5432/dbname

# SQLite file location (used only when DATABASE_URL is unset). On Render-with-a-disk,
# point this at the mount (e.g. /data/market_history.sqlite).
FANGTRACK_DB_PATH=database/market_history.sqlite

# Port (Render sets this automatically; used by wsgi.py's waitress fallback).
PORT=5000

# Optional: SMTP for watchlist digests AND password-reset emails (Gmail needs an
# App Password). When set, these ENV VARS OVERRIDE the in-app Settings, so production
# creds never live in the repo. Also accepts the FANGTRACK_-prefixed form.
# SMTP_HOST=smtp.gmail.com
# SMTP_PORT=587
# SMTP_USER=you@gmail.com
# SMTP_PASS=your-app-password
# NOTIFY_EMAIL=you@gmail.com

# Public base URL, used to build absolute links in emails (e.g. password reset).
# FANGTRACK_BASE_URL=https://fangtrack.onrender.com

# Trusted reverse-proxy hop count for real-client-IP detection (Render = 1).
# FANGTRACK_PROXY_HOPS=1
